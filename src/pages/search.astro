---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const collectionsMeta: Record<string, { title: string; base: string }> = {
  tafseer: { title: 'Tefsri i Kuranit', base: '/tafseer' },
  hadith: { title: 'Hadiths', base: '/hadith' },
  aqidah: { title: 'Doctrine of Monotheism', base: '/aqidah' },
  fiqh: { title: 'Summary of Fiqh', base: '/fiqh' },
  ethics: { title: 'Islamic Ethics', base: '/ethics' },
  sira: { title: "The Prophet's Biography", base: '/sira' },
};

const allEntries = [];
for (const key of Object.keys(collectionsMeta)) {
  const entries = await getCollection(key as any);
  for (const entry of entries) {
    allEntries.push({
      title: entry.data.title,
      summary: entry.data.summary,
      href: `${collectionsMeta[key].base}/${entry.slug}`,
      category: collectionsMeta[key].title,
    });
  }
}

const query = Astro.url.searchParams.get('q')?.trim().toLowerCase() ?? '';
const results = query
  ? allEntries.filter(
      (e) => e.title.toLowerCase().includes(query) || e.summary.toLowerCase().includes(query)
    )
  : [];
---
<Layout title={`Search — Islamic Knowledge Encyclopedia`}>
  <section class="search-page">
    <div class="container">
      <a class="back-link" href="/">&larr; All categories</a>
      <h1>Search results</h1>
      <form action="/search" method="get" class="search-form">
        <input type="search" name="q" value={query} placeholder="Search everything .." aria-label="Search" />
        <button type="submit">Search</button>
      </form>

      {query && (
        <p class="result-count">{results.length} result{results.length === 1 ? '' : 's'} for &ldquo;{query}&rdquo;</p>
      )}

      <ul>
        {results.map((r) => (
          <li>
            <a href={r.href}>
              <span class="category-label">{r.category}</span>
              <h2>{r.title}</h2>
              <p>{r.summary}</p>
            </a>
          </li>
        ))}
      </ul>

      {query && results.length === 0 && <p class="empty">No entries matched your search yet.</p>}
    </div>
  </section>
</Layout>

<style>
  .search-page {
    padding: 40px 0 60px;
  }
  .back-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-sage);
  }
  .search-form {
    display: flex;
    gap: 10px;
    max-width: 520px;
    margin: 20px 0 8px;
  }
  .search-form input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    font-family: var(--font-body);
  }
  .search-form button {
    padding: 12px 22px;
    background: var(--color-gold);
    color: var(--color-white);
    border: none;
    border-radius: 999px;
    font-weight: 600;
  }
  .search-form button:hover {
    background: var(--color-gold-dark);
  }
  .result-count {
    color: var(--color-sage);
    font-size: 0.9rem;
  }
  ul {
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  li a {
    display: block;
    background: var(--color-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: 20px 24px;
  }
  li a:hover {
    border-color: var(--color-gold);
  }
  .category-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gold-dark);
  }
  li h2 {
    font-size: 1.1rem;
    margin: 6px 0;
  }
  li p {
    color: var(--color-sage);
    font-size: 0.92rem;
    margin: 0;
  }
  .empty {
    color: var(--color-sage);
  }
</style>
