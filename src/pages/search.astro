---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const collectionsMeta: Record<string, { title: string; base: string }> = {
  tafseer: { title: 'Tafseer of the Quran', base: '/tafseer' },
  hadith: { title: 'Hadiths', base: '/hadith' },
  aqidah: { title: 'Doctrine of Monotheism', base: '/aqidah' },
  fiqh: { title: 'Summary of Fiqh', base: '/fiqh' },
  ethics: { title: 'Islamic Ethics', base: '/ethics' },
  sira: { title: "The Prophet's Biography", base: '/sira' },
};

const allEntries = [];
for (const key of Object.keys(collectionsMeta)) {
  const entries = await getCollection(key as any);
  for (const entry of entries) {
    allEntries.push({
      title: entry.data.title,
      summary: entry.data.summary,
      href: `${collectionsMeta[key].base}/${entry.slug}`,
      category: collectionsMeta[key].title,
    });
  }
}
---
<Layout title="Search — Islamic Knowledge Encyclopedia">
  <section class="search-page">
    <div class="container">
      <a class="back-link" href="/">&larr; All categories</a>
      <h1>Search results</h1>
      <form class="search-form" id="searchForm">
        <input type="search" id="searchInput" name="q" placeholder="Search everything .." aria-label="Search" />
        <button type="submit">Search</button>
      </form>

      <p class="result-count" id="resultCount" hidden></p>
      <ul id="resultsList"></ul>
      <p class="empty" id="emptyMessage" hidden>No entries matched your search yet.</p>
      <p class="hint" id="hintMessage">Start typing above to search across all six categories.</p>
    </div>
  </section>
</Layout>

<script define:vars={{ allEntries }}>
  const input = document.getElementById('searchInput');
  const list = document.getElementById('resultsList');
  const resultCount = document.getElementById('resultCount');
  const emptyMessage = document.getElementById('emptyMessage');
  const hintMessage = document.getElementById('hintMessage');

  function render(query) {
    const q = query.trim().toLowerCase();

    if (!q) {
      list.innerHTML = '';
      resultCount.hidden = true;
      emptyMessage.hidden = true;
      hintMessage.hidden = false;
      return;
    }

    hintMessage.hidden = true;

    const results = allEntries.filter(
      (e) => e.title.toLowerCase().includes(q) || e.summary.toLowerCase().includes(q)
    );

    resultCount.hidden = false;
    resultCount.textContent = `${results.length} result${results.length === 1 ? '' : 's'} for "${query}"`;

    emptyMessage.hidden = results.length !== 0;

    list.innerHTML = results
      .map(
        (r) => `
        <li>
          <a href="${r.href}">
            <span class="category-label">${r.category}</span>
            <h2>${r.title}</h2>
            <p>${r.summary}</p>
          </a>
        </li>`
      )
      .join('');
  }

  const params = new URLSearchParams(window.location.search);
  const initialQuery = params.get('q') || '';
  input.value = initialQuery;
  render(initialQuery);

  input.addEventListener('input', () => {
    render(input.value);
    const url = new URL(window.location.href);
    if (input.value) {
      url.searchParams.set('q', input.value);
    } else {
      url.searchParams.delete('q');
    }
    window.history.replaceState({}, '', url);
  });

  document.getElementById('searchForm').addEventListener('submit', (e) => e.preventDefault());
</script>

<style>
  .search-page {
    padding: 40px 0 60px;
  }
  .back-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-sage);
  }
  .search-form {
    display: flex;
    gap: 10px;
    max-width: 520px;
    margin: 20px 0 8px;
  }
  .search-form input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    font-family: var(--font-body);
  }
  .search-form input:focus {
    outline: none;
    border-color: var(--color-gold);
  }
  .search-form button {
    padding: 12px 22px;
    background: var(--color-gold);
    color: var(--color-white);
    border: none;
    border-radius: 999px;
    font-weight: 600;
  }
  .search-form button:hover {
    background: var(--color-gold-dark);
  }
  .result-count, .hint {
    color: var(--color-sage);
    font-size: 0.9rem;
  }
  ul {
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  li a {
    display: block;
    background: var(--color-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: 20px 24px;
  }
  li a:hover {
    border-color: var(--color-gold);
  }
  .category-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gold-dark);
  }
  li h2 {
    font-size: 1.1rem;
    margin: 6px 0;
  }
  li p {
    color: var(--color-sage);
    font-size: 0.92rem;
    margin: 0;
  }
  .empty {
    color: var(--color-sage);
  }
</style>
