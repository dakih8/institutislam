---
import Layout from '../layouts/Layout.astro';
import CategoryCard from '../components/CategoryCard.astro';

const icons = {
  book: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v17H6.5A2.5 2.5 0 0 0 4 21.5v-17Z" stroke="currentColor" stroke-width="1.6"/><path d="M4 19a2.5 2.5 0 0 1 2.5-2.5H20" stroke="currentColor" stroke-width="1.6"/></svg>`,
  bubble: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M21 12a8 8 0 1 1-3.2-6.4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M21 4v5h-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.6"/></svg>`,
  compass: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M15 9l-2.5 5.5L7 17l2.5-5.5L15 9Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
  scale: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 3v18M4 7h16M6 7 3 13a3 3 0 0 0 6 0L6 7ZM18 7l-3 6a3 3 0 0 0 6 0l-3-6Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round"/></svg>`,
  leaf: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 4S6 5 6 15c0 3 2 5 5 5 8 0 9-14 9-16Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M8 20c1-4 4-8 12-14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
  moon: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 14.5A8.5 8.5 0 1 1 9.5 4a7 7 0 0 0 10.5 10.5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
};

const categories = [
  { key: 'tafseer', title: 'Tafseer of the Quran', description: 'The overall meaning of Quranic verses, drawn from trusted classical commentary.', icon: icons.book, href: '/tafseer' },
  { key: 'hadith', title: 'Hadiths', description: 'Authentic hadiths with explanations of their meanings and benefits.', icon: icons.bubble, href: '/hadith' },
  { key: 'aqidah', title: 'Doctrine of Monotheism', description: 'Core Islamic beliefs on the oneness of Allah, drawn from the Aqidah encyclopedia.', icon: icons.compass, href: '/aqidah' },
  { key: 'fiqh', title: 'Summary of Fiqh', description: 'Purity, prayer, fasting, zakat, hajj, family matters, and transactions.', icon: icons.scale, href: '/fiqh' },
  { key: 'ethics', title: 'Islamic Ethics', description: 'Teachings on character, conduct, and dealing with others.', icon: icons.leaf, href: '/ethics' },
  { key: 'sira', title: 'The Prophet\u2019s Biography', description: 'The life story of Prophet Muhammad, peace be upon him, from birth to prophethood.', icon: icons.moon, href: '/sira' },
];
---
<Layout title="Islamic Knowledge Encyclopedia — Tafseer, Hadith, Aqidah, Fiqh, Ethics & Sira">
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">A structured reference, verse by verse and narration by narration</p>
      <h1>Islamic Knowledge, Organized and Searchable</h1>
      <p class="hero-sub">Explore six core areas of Islamic knowledge — each entry summarized, sourced, and easy to search.</p>
    </div>
  </section>

  <section class="categories">
    <div class="container grid">
      {categories.map((c) => (
        <CategoryCard title={c.title} description={c.description} icon={c.icon} href={c.href} />
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 48px 0 32px;
  }
  .hero-eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold-dark);
    font-weight: 600;
    margin-bottom: 10px;
  }
  .hero h1 {
    font-size: 2.4rem;
    max-width: 780px;
  }
  .hero-sub {
    color: var(--color-sage);
    font-size: 1.05rem;
    max-width: 640px;
  }

  .categories {
    padding-bottom: 60px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .hero h1 {
      font-size: 1.9rem;
    }
  }
</style>
