---
import Layout from '../layouts/Layout.astro';

interface EntryLike {
  slug: string;
  data: {
    title: string;
    summary: string;
    source?: string;
    tags?: string[];
    order?: number;
  };
}

interface Props {
  categoryTitle: string;
  categoryDescription: string;
  basePath: string; // e.g. "/hadith"
  entries: EntryLike[];
}

const { categoryTitle, categoryDescription, basePath, entries } = Astro.props;

const sorted = [...entries].sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---
<Layout title={`${categoryTitle} — Islamic Knowledge Encyclopedia`} description={categoryDescription}>
  <section class="category-hero">
    <div class="container">
      <a class="back-link" href="/">&larr; All categories</a>
      <h1>{categoryTitle}</h1>
      <p>{categoryDescription}</p>

      <form class="filter-form" id="filterForm">
        <input type="search" id="filterInput" name="q" placeholder={`Search ${categoryTitle}..`} aria-label={`Search ${categoryTitle}`} />
      </form>
    </div>
  </section>

  <section class="entry-list">
    <div class="container">
      <p class="empty" id="emptyMessage" hidden>No entries matched your search.</p>
      <ul id="entryList">
        {sorted.map((entry) => (
          <li data-search={`${entry.data.title} ${entry.data.summary}`.toLowerCase()}>
            <a href={`${basePath}/${entry.slug}`}>
              <h2>{entry.data.title}</h2>
              <p>{entry.data.summary}</p>
              {entry.data.source && <span class="source">{entry.data.source}</span>}
            </a>
          </li>
        ))}
      </ul>
      {sorted.length === 0 && <p class="empty">No entries have been published in this category yet.</p>}
    </div>
  </section>
</Layout>

<script>
  // Static sites can't filter server-side per-request, so we do it here
  // in the browser: read ?q= from the real URL, filter the list client
  // side, and keep the URL in sync as the person types.
  const input = document.getElementById('filterInput') as HTMLInputElement | null;
  const list = document.getElementById('entryList');
  const emptyMessage = document.getElementById('emptyMessage');
  const items = list ? Array.from(list.querySelectorAll('li')) : [];

  function applyFilter(query: string) {
    const q = query.trim().toLowerCase();
    let visibleCount = 0;
    for (const item of items) {
      const haystack = item.getAttribute('data-search') || '';
      const match = q === '' || haystack.includes(q);
      (item as HTMLElement).style.display = match ? '' : 'none';
      if (match) visibleCount++;
    }
    if (emptyMessage) {
      emptyMessage.hidden = !(q !== '' && visibleCount === 0);
    }
  }

  const params = new URLSearchParams(window.location.search);
  const initialQuery = params.get('q') || '';
  if (input) {
    input.value = initialQuery;
  }
  applyFilter(initialQuery);

  if (input) {
    input.addEventListener('input', () => {
      applyFilter(input.value);
      const url = new URL(window.location.href);
      if (input.value) {
        url.searchParams.set('q', input.value);
      } else {
        url.searchParams.delete('q');
      }
      window.history.replaceState({}, '', url);
    });
  }

  const form = document.getElementById('filterForm');
  if (form) {
    form.addEventListener('submit', (e) => e.preventDefault());
  }
</script>

<style>
  .category-hero {
    padding: 40px 0 8px;
  }
  .back-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-sage);
  }
  .back-link:hover {
    color: var(--color-gold-dark);
  }
  .category-hero h1 {
    margin-top: 12px;
  }
  .category-hero p {
    color: var(--color-sage);
    max-width: 640px;
  }

  .filter-form {
    max-width: 420px;
    margin-top: 18px;
  }
  .filter-form input {
    width: 100%;
    padding: 12px 18px;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.95rem;
  }
  .filter-form input:focus {
    outline: none;
    border-color: var(--color-gold);
  }

  .entry-list {
    padding: 24px 0 60px;
  }
  .entry-list ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .entry-list li a {
    display: block;
    background: var(--color-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: 20px 24px;
  }
  .entry-list li a:hover {
    border-color: var(--color-gold);
  }
  .entry-list h2 {
    font-size: 1.15rem;
    margin-bottom: 6px;
  }
  .entry-list p {
    color: var(--color-sage);
    margin-bottom: 8px;
    font-size: 0.95rem;
  }
  .source {
    font-size: 0.78rem;
    color: var(--color-gold-dark);
    font-weight: 600;
  }
  .empty {
    color: var(--color-sage);
  }
</style>
