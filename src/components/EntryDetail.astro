---
import Layout from '../layouts/Layout.astro';

interface Props {
  categoryTitle: string;
  basePath: string;
  title: string;
  summary: string;
  source?: string;
  tags?: string[];
}

const { categoryTitle, basePath, title, summary, source, tags } = Astro.props;
---
<Layout title={`${title} — ${categoryTitle}`} description={summary}>
  <article class="entry">
    <div class="container">
      <a class="back-link" href={basePath}>&larr; {categoryTitle}</a>
      <h1>{title}</h1>
      <p class="summary">{summary}</p>
      {(source || (tags && tags.length > 0)) && (
        <div class="meta">
          {source && <span class="source">{source}</span>}
          {tags && tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
      <div class="motif-rule"></div>
      <div class="content">
        <slot />
      </div>
    </div>
  </article>
</Layout>

<style>
  .entry {
    padding: 40px 0 60px;
  }
  .back-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-sage);
  }
  .back-link:hover {
    color: var(--color-gold-dark);
  }
  .entry h1 {
    margin-top: 14px;
    max-width: 780px;
  }
  .summary {
    color: var(--color-sage);
    font-size: 1.05rem;
    max-width: 700px;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }
  .source, .tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 999px;
  }
  .source {
    background: var(--color-parchment-deep);
    color: var(--color-gold-dark);
  }
  .tag {
    background: #eef3ee;
    color: var(--color-green);
  }
  .motif-rule {
    margin: 8px 0 28px;
    border-radius: 4px;
  }
  .content {
    max-width: 720px;
    font-size: 1.02rem;
    line-height: 1.75;
  }
  .content :global(h2) {
    font-size: 1.25rem;
    margin-top: 1.6em;
  }
  .content :global(p) {
    margin-bottom: 1.2em;
  }
</style>
