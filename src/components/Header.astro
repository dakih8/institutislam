---
const categories = [
  { name: 'Tafseer', href: '/tafseer' },
  { name: 'Hadith', href: '/hadith' },
  { name: 'Aqidah', href: '/aqidah' },
  { name: 'Fiqh', href: '/fiqh' },
  { name: 'Ethics', href: '/ethics' },
  { name: 'Sira', href: '/sira' },
];
---
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-eyebrow">Islamic Knowledge</span>
      <span class="brand-name">Encyclopedia</span>
    </a>

    <form class="header-search" action="/search" role="search">
      <input type="search" name="q" placeholder="General search .." aria-label="General search" />
      <button type="submit" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </form>

    <button class="menu-toggle" aria-label="Open menu" aria-expanded="false" id="menuToggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="site-nav" id="siteNav">
    <div class="container nav-inner">
      {categories.map((c) => (
        <a href={c.href}>{c.name}</a>
      ))}
    </div>
  </nav>
</header>

<style>
  .site-header {
    background: var(--color-white);
    border-bottom: 1px solid var(--color-line);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 76px;
  }

  .brand {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
    flex-shrink: 0;
  }
  .brand-eyebrow {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gold-dark);
    font-weight: 600;
  }
  .brand-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-green-dark);
  }

  .header-search {
    flex: 1;
    display: flex;
    max-width: 640px;
    margin-left: auto;
    background: var(--color-parchment);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    overflow: hidden;
  }
  .header-search input {
    flex: 1;
    border: none;
    background: transparent;
    padding: 12px 20px;
    font-size: 0.95rem;
    color: var(--color-ink);
    font-family: var(--font-body);
  }
  .header-search input:focus {
    outline: none;
  }
  .header-search button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    background: var(--color-gold);
    color: var(--color-white);
    border: none;
  }
  .header-search button:hover {
    background: var(--color-gold-dark);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: 8px;
  }
  .menu-toggle span {
    width: 22px;
    height: 2px;
    background: var(--color-ink);
    display: block;
  }

  .site-nav {
    border-top: 1px solid var(--color-line);
    background: var(--color-parchment-deep);
  }
  .nav-inner {
    display: flex;
    gap: 28px;
    padding: 10px 24px;
    overflow-x: auto;
  }
  .nav-inner a {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-green);
    white-space: nowrap;
    padding: 4px 0;
    border-bottom: 2px solid transparent;
  }
  .nav-inner a:hover {
    border-color: var(--color-gold);
  }

  @media (max-width: 760px) {
    .header-search {
      display: none;
    }
    .menu-toggle {
      display: flex;
      margin-left: auto;
    }
  }
</style>
